# RPC Gnosis (optional — faster receipt polling for viem runner)
# NEXT_PUBLIC_RPC_URL=https://rpc.gnosischain.com

# Mentor Circles avatar addresses (required for PAY / TRUST on-chain)
# Option A: one default address for all mentors (garage demo)
NEXT_PUBLIC_MENTOR_DEFAULT_ADDRESS=0xYourCirclesAvatarAddress
# Option B: per mentor (overrides default)
# NEXT_PUBLIC_MENTOR_ZET_ADDRESS=0x...
# NEXT_PUBLIC_MENTOR_FLO_ADDRESS=0x...
# NEXT_PUBLIC_MENTOR_DIMITRY_ADDRESS=0x...
# NEXT_PUBLIC_MENTOR_VINCENT_ADDRESS=0x...
