# Public client env vars (required at Docker build time for Next.js)
NEXT_PUBLIC_FOUNDATION_ADDRESS=0x2b5E4045936ef12250a8c01e4Cbf71E9bEE69e00
NEXT_PUBLIC_BOOKING_PRICE_CRC=100

# Coolify / production iframe CSP — set to your HTTPS app origin, e.g. https://thp-for-good.example.org
NEXT_PUBLIC_FRAME_ANCESTOR_ORIGIN=

# Server-only notification secrets (runtime on Coolify — do not commit values)
N8N_NOTIFY_WEBHOOK_URL=
# RESEND_API_KEY=
