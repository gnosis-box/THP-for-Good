# RPC Gnosis (optional — faster receipt polling)
# NEXT_PUBLIC_RPC_URL=https://rpc.gnosischain.com

# Fondation THP for Good — tous les paiements mentor vont ici (100 CRC par réservation).
# Adresse du groupe Circles ; le trésor (treasury) est résolu automatiquement au paiement.
NEXT_PUBLIC_FOUNDATION_ADDRESS=0x2b5E4045936ef12250a8c01e4Cbf71E9bEE69e00

# Prix en CRC (défaut 100)
# NEXT_PUBLIC_BOOKING_PRICE_CRC=100

# Adresses Circles des mentors — profils + TRUST uniquement (pas le paiement).
# Option A : une adresse par défaut pour tous les mentors sans override
# NEXT_PUBLIC_MENTOR_DEFAULT_ADDRESS=0x...
# Option B : par mentor
# NEXT_PUBLIC_MENTOR_ZET_ADDRESS=0x...
# NEXT_PUBLIC_MENTOR_FLO_ADDRESS=0x...
# NEXT_PUBLIC_MENTOR_DIMITRY_ADDRESS=0x...
# NEXT_PUBLIC_MENTOR_VINCENT_ADDRESS=0x...
