# Reserved for app-specific public env vars.
# Anything that ships to the client must be prefixed NEXT_PUBLIC_.
# The miniapp SDK itself needs no configuration — the host injects the wallet at runtime.

# Cal.com OAuth client ID (create at app.cal.com → Settings → Developer → OAuth Apps)
# Must be a PUBLIC client with PKCE enabled. Register /cal/callback as a redirect URI.
NEXT_PUBLIC_CAL_OAUTH_CLIENT_ID=

# Cal.com API key (optional — used server-side for reading available slots)
CAL_API_KEY=

# GitHub new-issue URL for the in-app "Report issue" footer link (optional override)
# Default: user_feedback.yml template on gnosis-box/THP-for-Good
NEXT_PUBLIC_GITHUB_ISSUES_URL=

# Optional build/version label prefilled in feedback issues (set in Coolify at build time)
NEXT_PUBLIC_APP_VERSION=

# THP Circles group — admin Promote member list (see spec/useful-links.md)
GROUP_ADDRESS=

# Optional — filter Circles Explorer event feeds on /stats (see spec/analytics-strategy.md)
THP_ANALYTICS_START_BLOCK=

# Umami — UX analytics only (see spec/analytics-strategy.md §6)
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://mestryx.stats.gnosis.box/script.js
NEXT_PUBLIC_UMAMI_DASHBOARD_URL=https://mestryx.stats.gnosis.box
