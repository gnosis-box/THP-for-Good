#!/usr/bin/env bash
# cpdb — copy the THP for Good SQLite DB between Coolify environments
#
# Install on the server:
#   cp scripts/cpdb /usr/local/bin/cpdb && chmod +x /usr/local/bin/cpdb
#
# Requires: fzf, sqlite3, docker
# Usage: cpdb
#   Pick source with ↑↓ + Enter, targets with Tab (multi-select) + Enter.
#   Always snapshots prod to /root/thp-db-snapshots/ on every run.

set -euo pipefail

# ── config ───────────────────────────────────────────────────────────────────
readonly SNAPSHOT_DIR="/root/thp-db-snapshots"
readonly DB_PATH="/app/data/thp.db"
readonly PROJECT_LABEL="thp-for-good"
readonly KEEP_SNAPSHOTS=10
# ─────────────────────────────────────────────────────────────────────────────

R='\033[0;31m' G='\033[0;32m' C='\033[0;36m' B='\033[1m' N='\033[0m'

die() { echo -e "${R}Error:${N} $*" >&2; exit 1; }
command -v fzf    >/dev/null || die "fzf not found. Install: apt install fzf"
command -v sqlite3 >/dev/null || die "sqlite3 not found."

mkdir -p "$SNAPSHOT_DIR"

# ── discover THP containers ──────────────────────────────────────────────────
# Each entry: "FQDN|cname|env|prid" — sorted so prod is always first.
RAW_ENTRIES=()
while IFS='|' read -r _key cname fqdn env prid; do
  docker exec "$cname" test -f "$DB_PATH" 2>/dev/null || continue
  RAW_ENTRIES+=("${fqdn}|${cname}|${env}|${prid}")
done < <(
  docker ps --format '{{.Names}}' | while read -r name; do
    read -r proj fqdn env prid < <(docker inspect "$name" --format \
      '{{index .Config.Labels "coolify.projectName"}} {{index .Config.Labels "caddy_0"}} {{index .Config.Labels "coolify.environmentName"}} {{index .Config.Labels "coolify.pullRequestId"}}' \
      2>/dev/null || echo "")
    [[ "$proj" == "$PROJECT_LABEL" ]] || continue
    fqdn="${fqdn#https://}"
    # Sort key uses _ not | so it doesn't break IFS='|' parsing in the outer loop
    if   [[ "$env" == "production" && "$prid" == "0" ]]; then key="0_${env}_$(printf '%05d' "$prid")"
    elif [[ "$env" == "production" ]];                    then key="1_${env}_$(printf '%05d' "$prid")"
    elif [[ "$prid" == "0" ]];                            then key="2_${env}_$(printf '%05d' "$prid")"
    else                                                       key="3_${env}_$(printf '%05d' "$prid")"
    fi
    echo "${key}|${name}|${fqdn}|${env}|${prid}"
  done | sort
)

[[ ${#RAW_ENTRIES[@]} -gt 0 ]] || die "No THP for Good containers with $DB_PATH found."

# ── helpers ──────────────────────────────────────────────────────────────────
entry_fqdn()  { echo "${RAW_ENTRIES[$1]}" | cut -d'|' -f1; }
entry_cname() { echo "${RAW_ENTRIES[$1]}" | cut -d'|' -f2; }
entry_env()   { echo "${RAW_ENTRIES[$1]}" | cut -d'|' -f3; }
entry_prid()  { echo "${RAW_ENTRIES[$1]}" | cut -d'|' -f4; }

is_prod_main() {
  [[ "$(entry_env $1)" == "production" && "$(entry_prid $1)" == "0" ]]
}
is_dev_env() { [[ "$(entry_env $1)" == "dev" ]]; }

snapshot_from_container() {
  local cname=$1 dest=$2 tmp="/tmp/thp_cpdb_src_$$.db"
  docker cp "$cname:$DB_PATH" "$tmp"
  docker cp "$cname:${DB_PATH}-wal" "${tmp}-wal" 2>/dev/null || true
  docker cp "$cname:${DB_PATH}-shm" "${tmp}-shm" 2>/dev/null || true
  sqlite3 "$tmp" ".backup $dest"
  rm -f "$tmp" "${tmp}-wal" "${tmp}-shm"
}

# Build fzf display line: "fqdn  [env-label]"
fzf_line() {
  local i=$1 env prid fqdn label
  fqdn="$(entry_fqdn $i)"; env="$(entry_env $i)"; prid="$(entry_prid $i)"
  if   [[ "$env" == "production" && "$prid" == "0" ]]; then label="prod"
  elif [[ "$env" == "production" ]];                    then label="prod · PR #$prid"
  elif [[ "$prid" == "0" ]];                            then label="$env"
  else                                                       label="$env · PR #$prid"
  fi
  printf "%-38s  [%s]" "$fqdn" "$label"
}

# ── header ───────────────────────────────────────────────────────────────────
echo ""
echo -e "${B}┌──────────────────────────────────────────┐${N}"
echo -e "${B}│   THP for Good  ·  cpdb                  │${N}"
echo -e "${B}└──────────────────────────────────────────┘${N}"

# ── prod snapshot (always) ───────────────────────────────────────────────────
PROD_IDX=-1
for i in "${!RAW_ENTRIES[@]}"; do is_prod_main $i && PROD_IDX=$i && break; done

SNAP_FILE=""
if [[ $PROD_IDX -ge 0 ]]; then
  LAST_SNAP=$(ls -t "$SNAPSHOT_DIR"/prod_*.db 2>/dev/null | head -1 || true)
  if [[ -n "$LAST_SNAP" ]]; then
    AGE_S=$(( $(date +%s) - $(stat -c %Y "$LAST_SNAP") ))
    if   (( AGE_S < 60 ));   then AGE_STR="${AGE_S}s ago"
    elif (( AGE_S < 3600 )); then AGE_STR="$(( AGE_S / 60 ))m ago"
    else                          AGE_STR="$(( AGE_S / 3600 ))h $(( (AGE_S % 3600) / 60 ))m ago"
    fi
    echo -e "\n${C}Last prod snapshot:${N} $(basename "$LAST_SNAP")  (${AGE_STR})"
  else
    echo -e "\n${C}No previous prod snapshot found.${N}"
  fi

  SNAP_FILE="$SNAPSHOT_DIR/prod_$(date +%Y%m%d_%H%M%S).db"
  echo -ne "${C}Snapshotting prod...${N} "
  snapshot_from_container "$(entry_cname $PROD_IDX)" "$SNAP_FILE"
  SNAP_ROWS=$(sqlite3 "$SNAP_FILE" "SELECT count(*) FROM bookings;" 2>/dev/null || echo "?")
  echo -e "${G}✓${N}  $(basename "$SNAP_FILE")  (${SNAP_ROWS} bookings)"

  mapfile -t OLD_SNAPS < <(ls -t "$SNAPSHOT_DIR"/prod_*.db 2>/dev/null | tail -n +$(( KEEP_SNAPSHOTS + 1 )))
  (( ${#OLD_SNAPS[@]} > 0 )) && rm -f "${OLD_SNAPS[@]}"
fi

# ── build fzf input lines (index embedded as hidden prefix) ──────────────────
# Format fed to fzf: "<idx>:<display line>" — we strip the prefix after selection.
SRC_LINES=(); TGT_LINES=()
PROD_DEFAULT_LINE=""
for i in "${!RAW_ENTRIES[@]}"; do
  line="${i}:$(fzf_line $i)"
  SRC_LINES+=("$line")
  is_prod_main $i && PROD_DEFAULT_LINE="$line"
done

# ── pick SOURCE (single select, prod pre-selected) ────────────────────────────
echo ""
SRC_LINE=$(
  printf '%s\n' "${SRC_LINES[@]}" \
  | fzf --ansi --no-multi \
        --prompt="Source (copy FROM) › " \
        --header="↑↓ navigate · Enter select  (prod is first)" \
        --height=40% --border \
        || true
)
[[ -n "$SRC_LINE" ]] || die "No source selected."
SRC_IDX="${SRC_LINE%%:*}"

# ── pick TARGET(S) (multi-select, dev env pre-tagged) ────────────────────────
# Build target list excluding the chosen source; mark dev env with a bullet.
TGT_INPUT_LINES=(); TGT_PRESELECT=()
for i in "${!RAW_ENTRIES[@]}"; do
  [[ $i -eq $SRC_IDX ]] && continue
  line="${i}:$(fzf_line $i)"
  TGT_INPUT_LINES+=("$line")
  is_dev_env $i && TGT_PRESELECT+=("${line#*:}")
done

[[ ${#TGT_INPUT_LINES[@]} -gt 0 ]] || die "No other containers available as targets."

# Feed pre-selected lines first so fzf's --multi highlights them on start
# (fzf doesn't have a native "pre-check" flag, so we use a bind trick)
mapfile -t TGT_SELECTED < <(
  {
    # Print dev-env entries first (so --tac puts them at top = pre-highlighted)
    for l in "${TGT_INPUT_LINES[@]}"; do
      idx="${l%%:*}"
      is_dev_env $idx && echo "$l"
    done
    for l in "${TGT_INPUT_LINES[@]}"; do
      idx="${l%%:*}"
      is_dev_env $idx || echo "$l"
    done
  } \
  | fzf --ansi --multi \
        --prompt="Targets (copy TO) › " \
        --header="↑↓ navigate · Tab toggle · Enter confirm" \
        --height=50% --border \
        || true
)

# Re-select defaults (dev env) if user pressed Enter without touching anything
# fzf --multi with no selection = empty; treat that as "select all dev entries"
if [[ ${#TGT_SELECTED[@]} -eq 0 ]]; then
  for l in "${TGT_INPUT_LINES[@]}"; do
    idx="${l%%:*}"
    is_dev_env $idx && TGT_SELECTED+=("$l")
  done
fi
[[ ${#TGT_SELECTED[@]} -gt 0 ]] || die "No targets selected."

TGT_INDICES=()
for sel in "${TGT_SELECTED[@]}"; do
  idx="${sel%%:*}"
  [[ $idx -eq $SRC_IDX ]] && continue
  TGT_INDICES+=("$idx")
done
[[ ${#TGT_INDICES[@]} -gt 0 ]] || die "No valid targets."

# ── read source DB ────────────────────────────────────────────────────────────
echo ""
echo -e "${C}Reading DB from:${N} $(entry_fqdn $SRC_IDX)"
TMP_CLEAN="/tmp/thp_cpdb_clean_$$.db"

if is_prod_main $SRC_IDX && [[ -f "$SNAP_FILE" ]]; then
  cp "$SNAP_FILE" "$TMP_CLEAN"
else
  snapshot_from_container "$(entry_cname $SRC_IDX)" "$TMP_CLEAN"
fi

SRC_ROWS=$(sqlite3 "$TMP_CLEAN" "SELECT count(*) FROM bookings;" 2>/dev/null || echo "?")
echo -e "${G}✓${N}  Clean snapshot ready  (${SRC_ROWS} bookings)"

# ── copy to each target ───────────────────────────────────────────────────────
echo ""
for idx in "${TGT_INDICES[@]}"; do
  cname="$(entry_cname $idx)"
  fqdn="$(entry_fqdn $idx)"

  printf "  Copying  to %s ... " "$fqdn"
  docker cp "$TMP_CLEAN" "${cname}:${DB_PATH}"
  # docker cp creates a new inode owned by root; fix ownership with root exec
  docker exec -u root "$cname" chown nextjs:nogroup "$DB_PATH" 2>/dev/null || true
  docker exec -u root "$cname" rm -f "${DB_PATH}-shm" "${DB_PATH}-wal" 2>/dev/null || true
  echo -e "${G}✓${N}"

  # Restart so the app re-opens the new inode (docker cp replaces the file
  # but the running process still holds a fd to the old one)
  printf "  Restarting %s ... " "$fqdn"
  docker restart "$cname" >/dev/null
  echo -e "${G}✓${N}"
done

rm -f "$TMP_CLEAN"
echo ""
echo -e "${G}${B}Done.${N}"
echo ""
